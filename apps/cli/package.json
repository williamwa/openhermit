{
  "name": "openhermit",
  "version": "0.1.0",
  "description": "OpenHermit — multi-agent platform CLI",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/williamwa/openhermit.git",
    "directory": "apps/cli"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "cli",
    "multi-agent"
  ],
  "bin": {
    "openhermit": "src/cli.ts",
    "hermit": "src/cli.ts"
  },
  "files": [
    "dist/cli.js"
  ],
  "scripts": {
    "build": "tsc -b",
    "bundle": "tsup",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "npm run build && node --import tsx --test test/*.test.ts",
    "prepublishOnly": "tsup",
    "dev": "tsx src/cli.ts",
    "dev:chat": "tsx src/index.ts"
  },
  "dependencies": {
    "@mariozechner/pi-tui": "^0.57.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@openhermit/sdk": "0.1.0",
    "@openhermit/shared": "0.1.0",
    "tsup": "^8.5.1"
  }
}
