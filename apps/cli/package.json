{
  "name": "openhermit",
  "version": "0.3.8",
  "description": "OpenHermit — multi-agent platform CLI & server",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/williamwa/openhermit.git"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "cli",
    "multi-agent"
  ],
  "bin": {
    "openhermit": "dist/cli.js",
    "hermit": "dist/cli.js"
  },
  "files": [
    "dist/",
    "public/",
    "drizzle/"
  ],
  "scripts": {
    "build": "tsc -b",
    "bundle": "tsup",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "npm run build && node --import tsx --test test/*.test.ts",
    "prepublishOnly": "npm run bundle && npm run copy:assets",
    "copy:assets": "mkdir -p public/admin public/web drizzle && cp -r ../../apps/gateway/ui/dist/* public/admin/ 2>/dev/null; cp -r ../../apps/web/public/* public/web/ 2>/dev/null; cp -r ../../packages/store/drizzle/* drizzle/ 2>/dev/null; chmod +x dist/cli.js; true",
    "dev": "tsx src/cli.ts",
    "dev:chat": "tsx src/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@mariozechner/pi-agent-core": "^0.57.1",
    "@mariozechner/pi-ai": "^0.57.1",
    "@mariozechner/pi-tui": "^0.57.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "commander": "^12.1.0",
    "croner": "^10.0.1",
    "defuddle": "^0.11.0",
    "hono": "^4.7.2",
    "jose": "^6.2.2",
    "jsdom": "^24.0.0",
    "langfuse": "^3.38.6",
    "marked": "^15.0.12",
    "prom-client": "^15.1.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "remend": "^1.3.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@openhermit/agent": "0.2.0",
    "@openhermit/gateway": "0.2.0",
    "@openhermit/sdk": "0.2.0",
    "@openhermit/shared": "0.2.0",
    "@openhermit/store": "0.2.0",
    "@openhermit/web": "0.2.0",
    "tsup": "^8.5.1"
  }
}
