{
  "name": "@openhermit/agent",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "exports": {
    "./agent-runner": {
      "development": "./src/agent-runner.ts",
      "default": "./dist/agent-runner.js"
    },
    "./core": {
      "development": "./src/core/index.ts",
      "default": "./dist/core/index.js"
    },
    "./langfuse": {
      "development": "./src/langfuse.ts",
      "default": "./dist/langfuse.js"
    },
    "./channels": {
      "development": "./src/channels.ts",
      "default": "./dist/channels.js"
    },
    "./skills": {
      "development": "./src/skills.ts",
      "default": "./dist/skills.js"
    },
    "./metrics": {
      "development": "./src/metrics.ts",
      "default": "./dist/metrics.js"
    },
    "./model-catalog": {
      "development": "./src/model-catalog.ts",
      "default": "./dist/model-catalog.js"
    },
    "./events": {
      "development": "./src/events.ts",
      "default": "./dist/events.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.typecheck.json --pretty false",
    "test": "npm run build && node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.70.6",
    "@mariozechner/pi-ai": "^0.70.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openhermit/protocol": "0.2.0",
    "@openhermit/shared": "0.2.0",
    "@openhermit/store": "0.2.0",
    "croner": "^10.0.1",
    "defuddle": "^0.11.0",
    "e2b": "^2.19.4",
    "jsdom": "^24.0.0",
    "langfuse": "^3.38.6",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@openhermit/channel-telegram": "0.2.0"
  }
}
