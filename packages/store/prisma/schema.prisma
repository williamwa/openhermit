generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Meta {
  key   String @id
  value String

  @@map("meta")
}

model Session {
  agentId              String  @map("agent_id")
  sessionId            String  @map("session_id")
  sourceKind           String  @map("source_kind")
  sourcePlatform       String? @map("source_platform")
  interactive          Int
  createdAt            String  @map("created_at")
  lastActivityAt       String  @map("last_activity_at")
  description          String?
  descriptionSource    String? @map("description_source")
  messageCount         Int     @default(0) @map("message_count")
  completedTurnCount   Int     @default(0) @map("completed_turn_count")
  lastMessagePreview   String? @map("last_message_preview")
  workingMemory        String? @map("working_memory")
  workingMemoryUpdatedAt String? @map("working_memory_updated_at")
  metadataJson         String  @default("{}") @map("metadata_json")
  status               String  @default("idle")
  type                 String  @default("direct")

  events SessionEvent[]

  @@id([agentId, sessionId])
  @@index([agentId, lastActivityAt(sort: Desc)], map: "idx_sessions_agent")
  @@map("sessions")
}

model SessionEvent {
  id          Int     @id @default(autoincrement())
  agentId     String  @map("agent_id")
  sessionId   String  @map("session_id")
  ts          String
  eventType   String  @map("event_type")
  payloadJson String  @map("payload_json")
  content     String?
  userId      String? @map("user_id")

  session Session @relation(fields: [agentId, sessionId], references: [agentId, sessionId], onDelete: Cascade)

  @@index([agentId, sessionId, ts(sort: Desc)], map: "idx_session_events_agent_session")
  @@index([agentId, sessionId, eventType, id(sort: Desc)], map: "idx_session_events_type")
  @@map("session_events")
}

model Memory {
  agentId      String @map("agent_id")
  memoryKey    String @map("memory_key")
  content      String
  metadataJson String @default("{}") @map("metadata_json")
  createdAt    String @default("") @map("created_at")
  updatedAt    String @map("updated_at")

  @@id([agentId, memoryKey])
  @@index([agentId, updatedAt(sort: Desc)], map: "idx_memories_agent")
  @@map("memories")
}

model Container {
  agentId       String  @map("agent_id")
  containerName String  @map("container_name")
  containerType String  @map("container_type")
  image         String
  status        String
  description   String?
  metadataJson  String  @map("metadata_json")
  updatedAt     String  @map("updated_at")

  @@id([agentId, containerName])
  @@index([agentId, containerName], map: "idx_containers_agent")
  @@map("containers")
}

model Instruction {
  agentId   String @map("agent_id")
  key       String
  content   String
  updatedAt String @map("updated_at")

  @@id([agentId, key])
  @@map("instructions")
}

model User {
  agentId    String  @map("agent_id")
  userId     String  @map("user_id")
  role       String
  name       String?
  mergedInto String? @map("merged_into")
  createdAt  String  @map("created_at")
  updatedAt  String  @map("updated_at")

  identities UserIdentity[]

  @@id([agentId, userId])
  @@index([agentId, updatedAt(sort: Desc)], map: "idx_users_agent")
  @@map("users")
}

model UserIdentity {
  agentId       String @map("agent_id")
  userId        String @map("user_id")
  channel       String
  channelUserId String @map("channel_user_id")
  createdAt     String @map("created_at")

  user User @relation(fields: [agentId, userId], references: [agentId, userId], onDelete: Cascade)

  @@id([agentId, channel, channelUserId])
  @@index([agentId, userId], map: "idx_user_identities_user")
  @@map("user_identities")
}
