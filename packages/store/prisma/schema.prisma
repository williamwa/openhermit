generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Meta {
  key   String @id
  value String

  @@map("meta")
}

model Agent {
  agentId      String  @id @map("agent_id")
  name         String?
  configDir    String  @map("config_dir")
  workspaceDir String  @map("workspace_dir")
  createdAt    String  @map("created_at")
  updatedAt    String  @map("updated_at")

  users UserAgent[]

  @@map("agents")
}

model Session {
  agentId              String  @map("agent_id")
  sessionId            String  @map("session_id")
  sourceKind           String  @map("source_kind")
  sourcePlatform       String? @map("source_platform")
  interactive          Int
  createdAt            String  @map("created_at")
  lastActivityAt       String  @map("last_activity_at")
  description          String?
  descriptionSource    String? @map("description_source")
  messageCount         Int     @default(0) @map("message_count")
  completedTurnCount   Int     @default(0) @map("completed_turn_count")
  lastMessagePreview   String? @map("last_message_preview")
  workingMemory        String? @map("working_memory")
  workingMemoryUpdatedAt String? @map("working_memory_updated_at")
  metadataJson         String  @default("{}") @map("metadata_json")
  status               String  @default("idle")
  type                 String  @default("direct")
  userIdsJson          String  @default("[]") @map("user_ids_json")

  events SessionEvent[]

  @@id([agentId, sessionId])
  @@index([agentId, lastActivityAt(sort: Desc)], map: "idx_sessions_agent")
  @@map("sessions")
}

model SessionEvent {
  id          Int     @id @default(autoincrement())
  agentId     String  @map("agent_id")
  sessionId   String  @map("session_id")
  ts          String
  eventType   String  @map("event_type")
  payloadJson String  @map("payload_json")
  content     String?
  userId      String? @map("user_id")

  session Session @relation(fields: [agentId, sessionId], references: [agentId, sessionId], onDelete: Cascade)

  @@index([agentId, sessionId, ts(sort: Desc)], map: "idx_session_events_agent_session")
  @@index([agentId, sessionId, eventType, id(sort: Desc)], map: "idx_session_events_type")
  @@map("session_events")
}

model Memory {
  agentId      String @map("agent_id")
  memoryKey    String @map("memory_key")
  content      String
  metadataJson String @default("{}") @map("metadata_json")
  createdAt    String @default("") @map("created_at")
  updatedAt    String @map("updated_at")

  @@id([agentId, memoryKey])
  @@index([agentId, updatedAt(sort: Desc)], map: "idx_memories_agent")
  @@map("memories")
}

model Container {
  agentId       String  @map("agent_id")
  containerName String  @map("container_name")
  containerType String  @map("container_type")
  image         String
  status        String
  description   String?
  metadataJson  String  @map("metadata_json")
  updatedAt     String  @map("updated_at")

  @@id([agentId, containerName])
  @@index([agentId, containerName], map: "idx_containers_agent")
  @@map("containers")
}

model Instruction {
  agentId   String @map("agent_id")
  key       String
  content   String
  updatedAt String @map("updated_at")

  @@id([agentId, key])
  @@map("instructions")
}

model User {
  userId     String  @id @map("user_id")
  name       String?
  mergedInto String? @map("merged_into")
  createdAt  String  @map("created_at")
  updatedAt  String  @map("updated_at")

  identities UserIdentity[]
  agents     UserAgent[]

  @@index([updatedAt(sort: Desc)], map: "idx_users_updated")
  @@map("users")
}

model UserAgent {
  userId    String @map("user_id")
  agentId   String @map("agent_id")
  role      String
  createdAt String @map("created_at")

  user  User  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  agent Agent @relation(fields: [agentId], references: [agentId], onDelete: Cascade)

  @@id([userId, agentId])
  @@index([agentId], map: "idx_user_agents_agent")
  @@map("user_agents")
}

model UserIdentity {
  userId        String @map("user_id")
  channel       String
  channelUserId String @map("channel_user_id")
  createdAt     String @map("created_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([channel, channelUserId])
  @@index([userId], map: "idx_user_identities_user")
  @@map("user_identities")
}

model Skill {
  id           String @id
  name         String
  description  String
  path         String
  metadataJson String @default("{}") @map("metadata_json")
  createdAt    String @map("created_at")
  updatedAt    String @map("updated_at")

  agents AgentSkill[]

  @@map("skills")
}

model AgentSkill {
  agentId   String  @map("agent_id")
  skillId   String  @map("skill_id")
  enabled   Boolean @default(true)
  createdAt String  @map("created_at")

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([agentId, skillId])
  @@index([agentId], map: "idx_agent_skills_agent")
  @@map("agent_skills")
}

model Schedule {
  agentId        String  @map("agent_id")
  scheduleId     String  @map("schedule_id")
  type           String
  status         String  @default("active")
  cronExpression String? @map("cron_expression")
  runAt          String? @map("run_at")
  prompt         String
  sessionMode    String  @default("dedicated") @map("session_mode")
  deliveryJson   String  @default("\"silent\"") @map("delivery_json")
  policyJson     String  @default("{}") @map("policy_json")
  createdBy      String? @map("created_by")
  createdAt      String  @map("created_at")
  updatedAt      String  @map("updated_at")
  lastRunAt      String? @map("last_run_at")
  nextRunAt      String? @map("next_run_at")
  runCount       Int     @default(0) @map("run_count")
  consecutiveErrors Int  @default(0) @map("consecutive_errors")
  lastError      String? @map("last_error")

  runs ScheduleRun[]

  @@id([agentId, scheduleId])
  @@index([agentId, status], map: "idx_schedules_agent_status")
  @@index([agentId, nextRunAt], map: "idx_schedules_next_run")
  @@map("schedules")
}

model ScheduleRun {
  id          Int     @id @default(autoincrement())
  agentId     String  @map("agent_id")
  scheduleId  String  @map("schedule_id")
  status      String
  sessionId   String? @map("session_id")
  prompt      String
  startedAt   String  @map("started_at")
  finishedAt  String? @map("finished_at")
  durationMs  Int?    @map("duration_ms")
  error       String?

  schedule Schedule @relation(fields: [agentId, scheduleId], references: [agentId, scheduleId], onDelete: Cascade)

  @@index([agentId, scheduleId, startedAt(sort: Desc)], map: "idx_schedule_runs_schedule")
  @@map("schedule_runs")
}
