  },
  "dependencies": {
    "@openhermit/protocol": "0.1.0",
    "@openhermit/shared": "0.1.0",
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  }
}
