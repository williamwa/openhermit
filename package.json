{
  "name": "openhermit",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "apps/channels/*",
    "packages/*"
  ],
  "scripts": {
    "clean:build": "node scripts/clean-build.mjs",
    "build": "npm run clean:build && tsc -b",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run build && node --import tsx --test apps/agent/test/*.test.ts apps/cli/test/*.test.ts apps/web/test/*.test.ts",
    "dev:agent": "tsx apps/agent/src/index.ts",
    "chat:agent": "tsx apps/cli/src/index.ts",
    "dev:cli": "tsx apps/cli/src/index.ts",
    "dev:web": "tsx apps/web/src/index.ts",
    "dev:gateway": "tsx apps/gateway/src/index.ts",
    "dev:telegram": "tsx apps/channels/telegram/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
