{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@openhermit/protocol": [
        "packages/protocol/src/index.ts"
      ],
      "@openhermit/shared": [
        "packages/shared/src/index.ts"
      ],
      "@openhermit/sdk": [
        "packages/sdk/src/index.ts"
      ],
      "@openhermit/store": [
        "packages/store/src/index.ts"
      ],
      "@openhermit/agent/agent-runner": [
        "apps/agent/src/agent-runner.ts"
      ],
      "@openhermit/agent/core": [
        "apps/agent/src/core/index.ts"
      ],
      "@openhermit/agent/langfuse": [
        "apps/agent/src/langfuse.ts"
      ],
      "@openhermit/agent/channels": [
        "apps/agent/src/channels.ts"
      ]
    },
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "node"
    ],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  }
}
